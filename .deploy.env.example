RESOURCE_GROUP=""
WEBAPP_NAME="vu-dev"
WEBAPP_HOST="https://webapp-name.region.azurewebsites.net"

ENVIRONMENT="production"

POSTGRES_SERVER="db-name.postgres.database.azure.com"
POSTGRES_PORT="5432"
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_DB="va-dev-database"

AZURE_API_KEY_1=""
AZURE_API_BASE_1="https://resource-name.openai.azure.com/"
AZURE_API_VERSION_1="2024-12-01-preview"

AZURE_API_KEY_2=""
AZURE_API_BASE_2="https://resource-name.cognitiveservices.azure.com/"
AZURE_API_VERSION_2="2025-04-01-preview"

AZURE_API_KEY_3=""
AZURE_API_BASE_3="https://resource-name.services.ai.azure.com/openai/v1/"
AZURE_API_VERSION_3="2025-04-01-preview"

AZURE_MODEL_RESOURCE_MAP="gpt-5.2-chat:2"

MODELS="azure:gpt-5.2-chat,openrouter:*"

OPENAI_API_KEY=""
OPENROUTER_API_KEY=""

WORDPRESS_MIRROR_URL=""
WORDPRESS_WEBSITE_URL=""

BACKEND_CORS_ORIGINS="${WEBAPP_HOST},${WORDPRESS_MIRROR_URL}"

CHATBOT_MODEL="azure:gpt-5.2-chat"
CHATBOT_MODEL_TEMPERATURE="0.7"
EXTRACTOR_MODEL="azure:gpt-5.2-chat"
EXTRACTOR_MODEL_TEMPERATURE="0.1"
GUARDRAIL_MODEL="azure:gpt-5.2-chat"
GUARDRAIL_MODEL_TEMPERATURE="0.1"
SEARCH_AGENT_MODEL="azure:gpt-5.2-chat"
SEARCH_AGENT_MODEL_TEMPERATURE="0.0"
EVALUATION_MODEL="azure:gpt-5.2-chat"
EVALUATION_MODEL_TEMPERATURE="0.0"
SUMMARIZER_MODEL="azure:gpt-5.2-chat"

ENABLE_GUARDRAILS="true"
MAX_GUARDRAILS_RETRIES="2"

LLM_REQUEST_TIMEOUT="300"

USER_REGISTRATION_TOKEN=""
ADMIN_REGISTRATION_TOKEN=""
REGISTRATION_TOKEN=""
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES="1440"

SCHEDULER="false"

SCM_DO_BUILD_DURING_DEPLOYMENT="1"
WEBSITE_HTTPLOGGING_RETENTION_DAYS="30"

FRONTEND_DIR=""
INTERNAL_FRONTEND_DIR=""
