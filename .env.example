# Set API keys for your providers

OPENAI_API_KEY=

# Azure OpenAI Resource 1
AZURE_API_KEY_1=
AZURE_API_BASE_1=
AZURE_API_VERSION_1=2025-03-01-preview

# Azure OpenAI Resource 2
AZURE_API_KEY_2=
AZURE_API_BASE_2=
AZURE_API_VERSION_2=2025-03-01-preview

# Azure OpenAI Resource 3
AZURE_API_KEY_3=
AZURE_API_BASE_3=
AZURE_API_VERSION_3=2025-03-01-preview

# Model to Azure resource mapping (comma-separated model:resource pairs)
# Models not listed here default to resource 1
AZURE_MODEL_RESOURCE_MAP=gpt-4o:2,gpt-5.2-chat:2,DeepSeek-R1-0528:3,DeepSeek-V3-0324:3,DeepSeek-V3.1:3,DeepSeek-V3.2:3,gpt-oss-120b:3,grok-4-fast-non-reasoning:3,grok-4-fast-reasoning:3,Kimi-K2-Thinking:3,Mistral-Large-3:3

OPENROUTER_API_KEY=

# Enable specific models (comma-separated, supports wildcards)
MODELS=azure:gpt-4o,azure:gpt-4o-mini,azure:gpt-4.1,azure:gpt-4.1-mini,azure:gpt-5-mini,azure:gpt-5.1,azure:gpt-5.2,azure:gpt-5.2-chat,azure:gpt-oss-120b,azure:grok-4-fast-non-reasoning,azure:grok-4-fast-reasoning,azure:Kimi-K2-Thinking,azure:DeepSeek-V3-0324,azure:DeepSeek-R1-0528,azure:DeepSeek-V3.1,azure:DeepSeek-V3.2,azure:Mistral-Large-3,openrouter:*

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000,http://localhost:8080

DOCKER_IMAGE_BACKEND=backend
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local

# Demo university config (used in prompts and frontend)
UNIVERSITY_NAME=Demo University
UNIVERSITY_WEBSITE_URL=https://example.com
UNIVERSITY_ADMISSIONS_PHONE=111.222.3333
UNIVERSITY_TRANSCRIPTS_EMAIL=transcripts@example.com
UNIVERSITY_APPLICATION_URL=https://apply.example.com/?utm_source=VA
UNIVERSITY_ACCREDITATION_URL=https://example.com/about/accreditation-and-recognition/

# WordPress demo instance (used by the WP fetcher CLI)
WORDPRESS_MIRROR_URL=http://localhost:8080
WORDPRESS_WEBSITE_URL=http://localhost:8080
WORDPRESS_WIDGET_SCRIPT_URL=http://localhost:8000/public/chat-widget.js

# Frontend build
VITE_API_URL=http://localhost:8000/api

# Change this in production!
JWT_SECRET_KEY=jwt-secret

# Registration tokens - set these to enable registration for each role
# USER_REGISTRATION_TOKEN: For client frontend regular users
# ADMIN_REGISTRATION_TOKEN: For client frontend admin users
# DEV_REGISTRATION_TOKEN: For dev frontend users (developers)
# Change this in production!
USER_REGISTRATION_TOKEN=user
# Change this in production!
ADMIN_REGISTRATION_TOKEN=admin
# Change this in production!
DEV_REGISTRATION_TOKEN=dev

LOGFIRE_INSTRUMENT_DB=false
