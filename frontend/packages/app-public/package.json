{
    "name": "@va/app-public",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev-local": "vite --mode public-local",
        "build-local": "pnpm -w exec tsc -b packages/app-public && vite build --mode public-local",
        "build-stage": "pnpm -w exec tsc -b packages/app-public && vite build --mode public-stage",
        "build-prod": "pnpm -w exec tsc -b packages/app-public && vite build --mode public-prod",
        "type-check": "pnpm -w exec tsc -b --noEmit packages/app-public",
        "preview-local": "vite preview --mode public-local",
        "preview-stage": "vite preview --mode public-stage",
        "preview-prod": "vite preview --mode public-prod"
    },
    "dependencies": {
        "@va/shared": "workspace:*",
        "lucide-react": "^0.562.0",
        "nanoid": "^5.1.6",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-hook-form": "^7.69.0"
    },
    "devDependencies": {
        "vite": "^7.1.11"
    }
}
