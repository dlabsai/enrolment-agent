{
    "name": "@va/app-internal",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev-local": "vite --mode internal-local",
        "build-local": "pnpm -w exec tsc -b packages/app-internal && vite build --mode internal-local",
        "build-stage": "pnpm -w exec tsc -b packages/app-internal && vite build --mode internal-stage",
        "build-prod": "pnpm -w exec tsc -b packages/app-internal && vite build --mode internal-prod",
        "type-check": "pnpm -w exec tsc -b --noEmit packages/app-internal",
        "preview-local": "vite preview --mode internal-local",
        "preview-stage": "vite preview --mode internal-stage",
        "preview-prod": "vite preview --mode internal-prod"
    },
    "dependencies": {
        "@codemirror/language": "^6.11.3",
        "@codemirror/legacy-modes": "^6.5.2",
        "@codemirror/view": "^6.39.7",
        "@va/shared": "workspace:*",
        "@tabler/icons-react": "^3.36.1",
        "@tanstack/react-router": "^1.151.3",
        "@tanstack/react-table": "^8.21.3",
        "@uiw/codemirror-theme-github": "^4.25.4",
        "@uiw/react-codemirror": "^4.25.4",
        "codemirror": "^6.0.2",
        "lucide-react": "^0.562.0",
        "nanoid": "^5.1.6",
        "react": "^19.2.0",
        "react-base16-styling": "^0.10.0",
        "react-codemirror-merge": "^4.25.4",
        "react-dom": "^19.2.0",
        "react-error-boundary": "^4.0.13",
        "react-hook-form": "^7.69.0",
        "react-json-tree": "^0.20.0",
        "recharts": "^2.15.4",
        "sonner": "^2.0.7",
        "zustand": "^5.0.9"
    },
    "devDependencies": {
        "vite": "^7.1.11"
    }
}
